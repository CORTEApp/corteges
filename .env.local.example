NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Fallback legacy key only if your project still uses legacy JWT keys.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
# Optional, only needed for Supabase CLI tasks that require DB auth.
SUPABASE_DB_PASSWORD=

# Private app owner login. Run `npm run auth:master` after setting these.
user_master=
user_master_password=

# SharePoint import/export
SHAREPOINT_SITE_URL=https://corteapp.sharepoint.com/sites/Gestin
ENTRAID_CLIENT_ID=
# Optional. If empty, SharePoint export derives it from SHAREPOINT_SITE_URL when possible.
ENTRAID_TENANT_ID=
SHAREPOINT_EXPORT_DIR=.sharepoint-export

# Microsoft Graph delegated calendar / Teams meetings
MICROSOFT_GRAPH_TENANT_ID=organizations
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
# Must be the real public HTTPS origin registered in Microsoft Entra.
# Example: https://ges.corteapp.com
MICROSOFT_GRAPH_REDIRECT_BASE_URL=
MICROSOFT_GRAPH_REDIRECT_PATH=/integraciones/microsoft/callback
MICROSOFT_GRAPH_TOKEN_ENCRYPTION_KEY=
MICROSOFT_GRAPH_TIME_ZONE=Romance Standard Time

# Vercel Cron. Vercel sends this value as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Production origin and self-call URL for Coolify scheduled tasks.
APP_URL=https://ges.corteapp.es
NEXT_PUBLIC_APP_URL=https://ges.corteapp.es
CRON_BASE_URL=http://127.0.0.1:3000
